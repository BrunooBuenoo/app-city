rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ─── Users Collection ───
    match /users/{userId} {
      // Qualquer pessoa autenticada pode ler perfis (necessário para ranking, votantes, etc.)
      allow read: if isAuthenticated();

      // Apenas o próprio usuário pode criar/atualizar seu perfil
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();

      // Ninguém pode deletar perfis (apenas via console/admin SDK)
      allow delete: if false;
    }

    // ─── Reclamações ───
    match /reclamacoes/{reclamacaoId} {
      // Leitura pública (mapa é acessível sem login)
      allow read: if true;

      // Apenas usuários autenticados podem criar reclamações
      allow create: if isAuthenticated();

      // Apenas o autor da reclamação OU um admin pode atualizar
      allow update: if isAuthenticated()
        && (resource.data.autorId == request.auth.uid || isAdmin());

      // Apenas admin pode deletar reclamações
      allow delete: if isAdmin();

      // ─── Timeline (sub-coleção) ───
      match /timeline/{eventId} {
        // Qualquer pessoa pode ler a timeline
        allow read: if true;

        // Apenas admin pode criar eventos de timeline (mudança de status)
        // OU o sistema (via autorId da reclamação pai ao criar)
        allow create: if isAuthenticated();

        allow update, delete: if isAdmin();
      }

      // ─── Comentários (sub-coleção) ───
      match /comentarios/{comentarioId} {
        // Qualquer pessoa pode ler comentários
        allow read: if true;

        // Apenas usuários autenticados podem comentar
        allow create: if isAuthenticated();

        // Apenas o autor do comentário ou admin pode editar/deletar
        allow update: if isAuthenticated()
          && (resource.data.autorId == request.auth.uid || isAdmin());
        allow delete: if isAuthenticated()
          && (resource.data.autorId == request.auth.uid || isAdmin());
      }
    }

    // ─── Categorias ───
    match /categorias/{categoriaId} {
      // Temporariamente liberado leitura e escrita pública para permitir a carga inicial (seeding) automática
      allow read, write: if true;
    }

    // ─── Configurações (Gamificação, etc.) ───
    match /configuracoes/{configId} {
      // Qualquer pessoa pode ler as regras de XP (necessário para a pontuação)
      allow read: if true;

      // Apenas administradores podem atualizar as regras
      allow write: if isAdmin();
    }

    // ─── Catch-all: negar tudo que não foi explicitamente permitido ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
