rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUsuarioData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && getUsuarioData().funcao == "admin";
    }

    function isEmpresa(empresaId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (getUsuarioData().funcao == "empresa" && getUsuarioData().empresaId == empresaId);
    }

    function isParceiro(empresaId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (getUsuarioData().funcao == "parceiro" && getUsuarioData().empresaId == empresaId);
    }

    // ─── Coleção usuarios ───
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    // ─── Coleção empresas ───
    match /empresas/{empresaId} {
      // Qualquer usuário pode consultar informações comerciais públicas das empresas
      allow read: if true;
      allow write: if isAdmin();

      // ─── Estabelecimentos (Subcoleção) ───
      match /estabelecimentos/{estabId} {
        allow read: if true;
        
        // Apenas empresas parceiras da mesma empresa ou admin podem criar/atualizar estabelecimentos
        allow create, update: if isAdmin() || isEmpresa(empresaId);
        allow delete: if isAdmin();

        // ─── Cupons (Subcoleção) ───
        match /cupons/{cupomId} {
          allow read: if true;
          
          // Empresas, parceiros locais e admin podem gerenciar cupons
          allow create, update: if isAdmin() || isEmpresa(empresaId) || isParceiro(empresaId);
          allow delete: if isAdmin() || isEmpresa(empresaId);
        }

        // ─── Resgates (Subcoleção) ───
        match /resgates/{resgateId} {
          // Usuários autenticados podem ler seus resgates, e empresas/parceiros podem ler para validação
          allow read: if isAuthenticated();
          
          // Qualquer usuário logado pode gerar um resgate
          allow create: if isAuthenticated() && request.resource.data.usuarioId == request.auth.uid;
          
          // Apenas admin, empresa ou parceiro podem validar o resgate (mudar status para resgatado)
          allow update: if isAdmin() || isEmpresa(empresaId) || isParceiro(empresaId);
          allow delete: if isAdmin();
        }
      }
    }

    // ─── Categorias ───
    match /categorias/{categoriaId} {
      allow read, write: if true;
    }

    // ─── Catch-all: negar tudo que não foi explicitamente permitido ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
